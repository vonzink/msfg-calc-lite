<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %><%= site.siteName %></title>
  <link rel="icon" type="image/png" sizes="32x32" href="<%= site.favicon %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/base.css?v=<%= v %>">
  <link rel="stylesheet" href="/css/layout.css?v=<%= v %>">
  <link rel="stylesheet" href="/css/components.css?v=<%= v %>">
  <link rel="stylesheet" href="/css/print.css?v=<%= v %>" media="print">
  <link rel="stylesheet" href="/css/email-modal.css?v=<%= v %>">
  <%- typeof extraHead !== 'undefined' ? extraHead : '' %>
  <% var theme = typeof site !== 'undefined' && site.theme ? site.theme : {}; %>
  <% if (theme.primaryColor || theme.bodyFont) { %>
  <style>
    :root {
      <% if (theme.primaryColor) { %>--brand-primary: <%= theme.primaryColor %>;<% } %>
      <% if (theme.secondaryColor) { %>--brand-secondary: <%= theme.secondaryColor %>;<% } %>
      <% if (theme.accentColor) { %>--brand-accent: <%= theme.accentColor %>;<% } %>
      <% if (theme.lightColor) { %>--brand-light: <%= theme.lightColor %>;<% } %>
      <% if (theme.bodyFont) { %>--font-body: '<%= theme.bodyFont %>', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;<% } %>
      <% if (theme.headingFont) { %>--font-heading: '<%= theme.headingFont %>', 'Inter', sans-serif;<% } %>
    }
  </style>
  <% if (theme.bodyFont && theme.bodyFont !== 'Inter' || theme.headingFont && theme.headingFont !== 'Poppins') { %>
  <link href="https://fonts.googleapis.com/css2?<% if (theme.bodyFont && theme.bodyFont !== 'Inter') { %>family=<%= encodeURIComponent(theme.bodyFont) %>:wght@300;400;500;600;700&<% } %><% if (theme.headingFont && theme.headingFont !== 'Poppins' && theme.headingFont !== theme.bodyFont) { %>family=<%= encodeURIComponent(theme.headingFont) %>:wght@600;700&<% } %>display=swap" rel="stylesheet">
  <% } %>
  <% } %>
</head>
<body<%= typeof bodyClass !== 'undefined' ? ' class="' + bodyClass + '"' : '' %>>

  <%- include('../partials/header') %>

  <main class="site-main" data-ver="<%= v %>" data-js-ext="<%= jsExt %>"<% if (typeof calc !== 'undefined' && calc) { %> data-calc-icon="<%= calc.icon || '' %>" data-calc-slug="<%= calc.slug || '' %>"<% } %>>
    <%- body %>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/email-modal') %>
  <script src="/js/shared/utils<%= jsExt %>?v=<%= v %>"></script>
  <script src="/js/shared/file-upload-utils<%= jsExt %>?v=<%= v %>"></script>
  <script src="/js/shared/report<%= jsExt %>?v=<%= v %>"></script>
  <script src="/js/shared/calc-email<%= jsExt %>?v=<%= v %>"></script>
  <%- typeof extraScripts !== 'undefined' ? extraScripts : '' %>
</body>
</html>
